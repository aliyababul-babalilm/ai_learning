generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id              String               @id @default(uuid())
  name            String               @unique
  description     String?
  industry        String?
  modules         String[]             @default(["learning"]) // "learning", "assessment", or both
  companyContext   String?              // Admin-provided context about the company
  createdAt       DateTime             @default(now())
  questions       Question[]
  users           User[]
  departmentTemplates DepartmentTemplate[]
}

model Question {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  text       String
  category   String
  orderIndex Int      @default(0)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model User {
  id        String                @id @default(uuid())
  email     String                @unique
  name      String?
  companyId   String?
  company     Company?              @relation(fields: [companyId], references: [id])
  department  String?               // Auto-detected from role or admin-assigned
  role        String                @default("learner")
  assessmentSections String[]      @default([]) // e.g., ["registration", "personal_ai", "company_ai"]
  createdAt   DateTime              @default(now())
  responses   UserResponse[]
  assessments AssessmentResponse[]
  progress  LessonProgress[]
  examples  PersonalizedExample[]
  skills    GeneratedSkill[]
}

model UserResponse {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String?
  category   String
  answer     String
  createdAt  DateTime @default(now())
}

model Module {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  type        String
  orderIndex  Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id          String           @id @default(uuid())
  moduleId    String
  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug        String           @unique
  title       String
  description String?
  content     Json
  orderIndex  Int              @default(0)
  progress    LessonProgress[]
}

model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status         String    @default("not_started")
  userPrompt     String?
  aiFeedback     String?
  improvedPrompt String?
  finalSkillFile String?
  score          Int?
  builderState   Json? // accumulated state from previous lessons in the module
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, lessonId])
}

model PersonalizedExample {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonSlug  String
  before      String
  after       String
  explanation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonSlug])
}

model GeneratedSkill {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonSlug   String
  skillContent String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, lessonSlug])
}

model DepartmentTemplate {
  id        String               @id @default(uuid())
  companyId String
  company   Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String               // e.g., "Trading", "Finance", "HR"
  assessmentSections String[]    @default([]) // Admin-defined sections for this department
  questions DepartmentQuestion[]
  createdAt DateTime             @default(now())

  @@unique([companyId, name])
}

model DepartmentQuestion {
  id           String             @id @default(uuid())
  templateId   String
  template     DepartmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  text         String
  questionType String             @default("text") // "text", "single-select", "multi-select", "likert"
  options      Json?              // For select types: array of option strings
  category     String             // "role_context", "data_maturity", "ai_skills", "workflow"
  isRequired   Boolean            @default(true)
  orderIndex   Int                @default(0)
  createdAt    DateTime           @default(now())
}

model AssessmentResponse {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  section       String    // "registration", "data_maturity", "personal_ai", "company_ai"
  responses     Json      // Full response payload
  scores        Json?     // Calculated scores per dimension
  compositScore Float?    // Overall composite score for this section
  tier          String?   // Maturity/proficiency tier
  narrative     String?   // LLM-generated narrative
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, section])
}
